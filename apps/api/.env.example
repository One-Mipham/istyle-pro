# ── Server ──
PORT=3000
HOST=0.0.0.0

# ── Supabase ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb-secret-...

# ── AI: 腾讯混元 (国内首选) ──
AI_PROVIDER=auto
TENCENT_SECRET_ID=AKIDxxxxxxxx
TENCENT_SECRET_KEY=xxxxxxxx

# ── AI: Replicate (国际备用，混元不可用时自动切换) ──
REPLICATE_API_TOKEN=r8_...
REPLICATE_MODEL=prunaai/z-image-turbo-img2img

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── 成本控制 ──
WEEKLY_COST_LIMIT_USD=100

# ── 微信支付 (可选) ──
# WECHAT_PAY_MCH_ID=1234567890
# WECHAT_PAY_API_KEY=your-api-key
# WECHAT_PAY_NOTIFY_URL=https://istyle.app/api/payment/notify
